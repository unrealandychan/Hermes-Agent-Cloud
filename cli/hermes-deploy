  [[ -z "$CLOUD" ]] && CLOUD="$(config_get "cloud")"
  [[ -z "$CLOUD" ]] && { error "No deployment found. Run: hermes-agent-cloud deploy"; exit 1; }

  case "$CLOUD" in
